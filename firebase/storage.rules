rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // フィールド画像
    match /field-images/{imageId} {
      // 誰でも読み取り可能（viewer で表示するため）
      allow read: if true;
      // 認証済みユーザー（匿名含む）のみアップロード可能
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024  // 10MB 以下
                   && request.resource.contentType.matches('image/.*');
    }

  }
}
