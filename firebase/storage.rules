rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // フィールド画像（field-images/ と fields/ 両方のパスを許可）
    match /field-images/{imageId} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    match /fields/{imageId} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

  }
}
