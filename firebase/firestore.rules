rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    // ====================================================================
    // Events コレクション
    // ====================================================================
    match /events/{eventId} {
      allow read: if true;
      allow create: if isAuthenticated()
        && request.resource.data.keys().hasAll(['name', 'fieldId', 'date', 'createdAt'])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0;
      allow update: if isAuthenticated();
      allow delete: if false;
    }

    // ====================================================================
    // Fields コレクション
    // ====================================================================
    match /fields/{fieldId} {
      allow read: if true;
      allow create: if isAuthenticated()
        && request.resource.data.keys().hasAll(['name', 'boundary'])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0;
      allow update: if isAuthenticated();
      allow delete: if false;
    }

    // ====================================================================
    // Matches コレクション
    // ====================================================================
    match /matches/{matchId} {
      allow read: if true;
      allow create: if isAuthenticated()
        && request.resource.data.keys().hasAll(['fieldId', 'status', 'createdAt'])
        && request.resource.data.status == 'waiting';
      // ステータス更新のみ許可（fieldId改ざん禁止）
      allow update: if isAuthenticated()
        && request.resource.data.fieldId == resource.data.fieldId;
      allow delete: if false;

      // ================================================================
      // Player Logs サブコレクション
      // ================================================================
      match /player_logs/{playerId} {
        allow read: if true;
        // 自分のログのみ書き込み可能
        allow create: if isAuthenticated()
          && request.auth.uid == playerId
          && request.resource.data.keys().hasAll(['name', 'teamColor', 'route']);
        allow update: if isAuthenticated()
          && request.auth.uid == playerId;
        allow delete: if false;
      }

      // ================================================================
      // Calibrations サブコレクション（スポーンGPS記録）
      // ================================================================
      match /calibrations/{calibId} {
        allow read: if true;
        allow write: if isAuthenticated();
      }
    }
  }
}
